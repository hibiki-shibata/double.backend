// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client"
  output   = "../src/shared/infra/db/generated.prisma"
}

datasource db {
  provider = "postgresql"
}

//  User Model
enum UserStatus {
  ACTIVE
  SUSPEND
  DELETED
}

enum UserRoles {
  USER
  ADMIN
  DELETED
}

model User {
  id            String      @id @unique @default(uuid())
  name          String?     @unique
  display_name  String
  email_address String?     @unique
  password_hash String?
  status        UserStatus
  roles         UserRoles[] @default([USER])
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  bets               Bet[]
  predictions        Prediction[]
  walletTransactions WalletTransaction[]
  wallet             Wallet?

  @@index([name])
  @@index([email_address])
  @@index([status])
  @@index([roles])
}

// Wallet Model
enum WalletStatus {
  ACTIVE
  SUSPENDED
}

enum Currency {
  USD
  EUR
  JPY
}

model Wallet {
  id              String       @id @default(uuid())
  user_id         String       @unique
  user            User         @relation(fields: [user_id], references: [id], onDelete: Restrict)
  balance         BigInt       @default(0)
  currency        Currency     @default(USD)
  reserved_amount BigInt       @default(0)
  status          WalletStatus @default(ACTIVE)
  version         Int          @default(0)
  updated_at      DateTime     @updatedAt

  walletTransactions WalletTransaction[]

  @@index([user_id])
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAW
  BET
  PAYOUT
  REFUND
  CANCEL
}

model WalletTransaction {
  id             String                @id @default(uuid())
  wallet_id      String
  wallet         Wallet                @relation(fields: [wallet_id], references: [id], onDelete: Restrict)
  user_id        String
  user           User                  @relation(fields: [user_id], references: [id], onDelete: Restrict)
  prediction_id  String?
  prediction     Prediction?           @relation(fields: [prediction_id], references: [id], onDelete: Restrict)
  type           WalletTransactionType
  currency       Currency
  amount         BigInt
  balance_before BigInt
  balance_after  BigInt
  created_at     DateTime              @default(now())

  @@index([user_id])
  @@index([wallet_id])
  @@index([prediction_id])
  @@map("wallet_transaction")
}

// Market Model
enum MarketStatus {
  UPCOMING
  OPEN
  CLOSED
  RESOLVED
  PAYOUT
  CANCELLED
}

model Market {
  id          String       @id @default(uuid())
  title       String
  status      MarketStatus @default(UPCOMING)
  close_at   DateTime
  updated_at  DateTime     @updatedAt
  created_at  DateTime     @default(now())
  resolved_at DateTime?

  predictions Prediction[]

  @@index([status])
  @@index([close_at])
}

// Prediciton Model
enum PredictionStatus {
  UPCOMING
  OPEN
  RESOLVED
  WON
  LOST
  CANCELLED
}

model Prediction {
  id                 String           @id @default(uuid())
  market_id          String
  market             Market           @relation(fields: [market_id], references: [id], onDelete: Restrict)
  name               String
  total_participants Int
  bet_sum            BigInt
  status             PredictionStatus @default(UPCOMING)
  resolved_by_id     String?
  resolved_by        User?            @relation(fields: [resolved_by_id], references: [id], onDelete: Restrict)
  resolved_at        DateTime?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  version            Int              @default(0)

  bets                   Bet[]
  walletTransactions     WalletTransaction[]
  predictionTransactions PredictionTransaction[]

  @@index([market_id])
  @@index([resolved_by_id])
}

enum PredictionTransactionType {
  BET
  REFUND
  CANCEL
}

model PredictionTransaction {
  id                        String                    @id @default(uuid())
  transaction_type          PredictionTransactionType
  prediction_id             String
  prediction                Prediction                @relation(fields: [prediction_id], references: [id], onDelete: Restrict)
  total_participants_before Int
  total_participants_after  Int
  currency                  Currency
  bet_amount                BigInt
  bet_sum_before            BigInt
  bet_sum_after             BigInt
  created_at                DateTime                  @default(now())

  @@index([prediction_id])
  @@map("prediction_transaction")
}

// Bet Model
enum BetStatus {
  PENDING
  LOCKED
  WON
  LOST
  PAYOUT
  CANCELLED
}

model Bet {
  id            String     @id @default(uuid())
  user_id       String
  user          User       @relation(fields: [user_id], references: [id], onDelete: Restrict)
  prediction_id String
  prediction    Prediction @relation(fields: [prediction_id], references: [id], onDelete: Restrict)
  currency      Currency   @default(USD)
  bet_amount    BigInt
  payout_amount BigInt     @default(0)
  status        BetStatus  @default(PENDING)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  version       Int        @default(0)

  @@index([user_id])
  @@index([status])
  @@index([prediction_id])
}

