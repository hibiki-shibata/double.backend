{
  "name": "double.backend",
  "version": "1.0.0",
  "description": "This is a prediction market backend server, which handle core logics",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "build": "pnpm tsc --project tsconfig.build.json && pnpm tsc-alias --project tsconfig.build.json",
    "lint": "pnpm dlx eslint ./app/src/",
    "lint:fix": "pnpm dlx eslint ./app/src/",
    "migrate:dev": "pnpm dlx prisma migrate dev --name local-migration",
    "start": "pnpm build && node --env-file=.env dist/index.js"
  },
  "keywords": [],
  "author": "hibiki.shibata",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "exports": "./dist/index.js",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/cookie-parser": "^1.4.10",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "stripe": "^22.2.1",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.8"
  }
}