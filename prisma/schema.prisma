// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client"
  output   = "../src/shared/infra/db/generated.prisma"
}

datasource db {
  provider = "postgresql"
}

//  User Model
enum UserStatus {
  active
  suspend
  deleted
}

enum UserRoles {
  user
  admin
}

model User {
  id            String      @id @default(uuid())
  name          String      @unique
  display_name  String
  email_address String?     @unique
  password_hash String
  status        UserStatus
  roles         UserRoles[]
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  bets        Bet[]
  predictions Prediction[]
  wallets     Wallet[]

  @@index([name])
  @@index([email_address])
  @@index([status])
  @@index([roles])
}

// Wallet Model
enum WalletStatus {
  active
  suspended
}

enum Currency {
  USD
  EUR
  JPY
}

model Wallet {
  id              String       @id @default(uuid())
  user_id         String       @default(uuid())
  user            User         @relation(fields: [user_id], references: [id], onDelete: Restrict)
  balance         BigInt
  currency        Currency
  reserved_amount Int
  status          WalletStatus
  version         Int
  updated_at      DateTime     @updatedAt

  walletTransactions WalletTransaction[]

  @@index([user_id])
}

enum WalletTransactionType {
  deposit
  withdraw
  bet
  payout
  refund
  cancel
}

model WalletTransaction {
  id             String                @id @default(uuid())
  wallet_id      String
  wallet         Wallet                @relation(fields: [wallet_id], references: [id], onDelete: Restrict)
  prediction_id  String?
  prediction     Prediction?           @relation(fields: [prediction_id], references: [id], onDelete: Restrict)
  type           WalletTransactionType
  currency       Currency
  amount         Int
  balance_before Int
  balance_after  Int
  created_at     DateTime              @default(now())

  @@index([wallet_id])
  @@index([prediction_id])
  @@map("wallet_transaction")
}

// Market Model
enum MarketStatus {
  upcoming
  opened
  closed
  resolved
  payout
  cancelled
}

model Market {
  id          String       @id @default(uuid())
  title       String
  status      MarketStatus
  closed_at   DateTime
  updated_at  DateTime     @updatedAt
  resolved_at DateTime?

  bets        Bet[]
  predictions Prediction[]
}

// Prediciton Model
enum PredictionStatus {
  upcoming
  open
  resolved
  won
  lost
  cancelled
}

model Prediction {
  id                 String           @id @default(uuid())
  market_id          String           @default(uuid())
  market             Market           @relation(fields: [market_id], references: [id], onDelete: Restrict)
  name               String
  total_participants Int
  bet_sum            Int
  status             PredictionStatus
  resolved_by_id     String?
  resolved_by        User?            @relation(fields: [resolved_by_id], references: [id], onDelete: Restrict)
  resolved_at        DateTime?
  created_at         DateTime
  updated_at         DateTime         @updatedAt
  version            Int

  bets               Bet[]
  walletTransactions WalletTransaction[]

  @@index([market_id])
  @@index([resolved_by_id])
}

enum PredictionTransactionType {
  bet
  refund
  cancel
}

model PredictionTransaction {
  id                        String                    @id @default(uuid())
  prediction_id             String
  transaction_type          PredictionTransactionType
  total_participants_before Int
  total_participants_after  Int
  currency                  Currency
  bet_amount                Int
  bet_sum_before            Int
  bet_sum_after             Int
  created_at                DateTime

  @@map("prediction_transaction")
}

// Bet Model
enum BetStatus {
  pending
  locked
  won
  lost
  payout
  cancelled
}

model Bet {
  id            String     @id @default(uuid())
  user_id       String     @default(uuid())
  user          User       @relation(fields: [user_id], references: [id], onDelete: Restrict)
  market_id     String     @default(uuid())
  market        Market     @relation(fields: [market_id], references: [id], onDelete: Restrict)
  prediction_id String     @default(uuid())
  prediction    Prediction @relation(fields: [prediction_id], references: [id], onDelete: Restrict)
  currency      Currency
  bet_amount    Int
  payout_amount Int?
  status        BetStatus
  created_at    DateTime
  updated_at    DateTime   @updatedAt
  version       Int

  @@index([user_id])
  @@index([market_id])
  @@index([prediction_id])
}

